{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./ui",
    "outDir": "./export",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "incremental": false,
  },
  "include": ["ui"],
  "exclude": [
    "node_modules",
    "export",
    "src",
    "test",
    "docs",
    "public",
    "build",
    "dist",
    "out",
    "data",
    ".idea",
    ".vscode",
  ],
}
